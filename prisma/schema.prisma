generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id              String      @id @default(uuid())
  userEmail       String      @map("user_email")
  sessionName     String?     @map("session_name")
  topic           String?
  maturityLevel   String?     @map("maturity_level")
  startedAt       DateTime    @default(now()) @map("started_at")
  endedAt         DateTime?   @map("ended_at")
  status          String?     @default("active")
  keyInsights     Json?       @map("key_insights")
  nextFocus       String?     @map("next_focus")
  createdAt       DateTime    @default(now()) @map("created_at")

  dialogues       Dialogue[]
  caseStudies     CaseStudy[]

  @@index([userEmail])
  @@map("sessions")
}

model Dialogue {
  id              Int         @id @default(autoincrement())
  sessionId       String      @map("session_id")
  session         Session     @relation(fields: [sessionId], references: [id])
  round           Int?
  pelatisMessage  String?     @map("pelatis_message")
  layer1Output    Json?       @map("layer1_output")
  layer2Output    Json?       @map("layer2_output")
  sophiaQuestion  String?     @map("sophia_question")
  sophiaThinking  String?     @map("sophia_thinking")
  tokensUsed      Int?        @map("tokens_used")
  costUsd         Decimal?    @map("cost_usd")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("dialogues")
}

model CaseStudy {
  id                Int         @id @default(autoincrement())
  sessionId         String      @map("session_id")
  session           Session     @relation(fields: [sessionId], references: [id])
  title             String?
  summary           String?
  keyInsight        String?     @map("key_insight")
  criticalQuestions Json?       @map("critical_questions")
  resolution        String?
  lessonsLearned    Json?       @map("lessons_learned")
  published         Boolean?    @default(false)
  createdAt         DateTime    @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("case_studies")
}
